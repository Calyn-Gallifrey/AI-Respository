<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.carddemo.mapper.BusinessCardMapper">
    <resultMap id="BusinessCardMap" type="com.demo.carddemo.model.BusinessCard">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="card_type" property="cardType" />
        <result column="title" property="title" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <select id="findByUserId" parameterType="long" resultMap="BusinessCardMap">
        SELECT * FROM business_card WHERE user_id = #{userId}
    </select>

    <select id="findById" parameterType="long" resultMap="BusinessCardMap">
        SELECT * FROM business_card WHERE id = #{id}
    </select>
</mapper>
